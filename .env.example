# COINBITCLUB MARKET BOT ENTERPRISE v6.0.0
# Arquivo de configuração de exemplo - COPIE PARA .env E CONFIGURE

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DATABASE_URL=postgresql://username:password@host:port/database

# ==============================================
# TWILIO SMS/OTP CONFIGURATION
# ==============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ==============================================
# STRIPE PAYMENTS CONFIGURATION
# ==============================================
# Para teste (recomendado para desenvolvimento):
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx

# Para produção:
# STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxx

# ==============================================
# JWT & SECURITY
# ==============================================
JWT_SECRET=seu_jwt_secret_super_seguro_aqui
ENCRYPTION_KEY=sua_chave_de_criptografia_super_segura_aqui

# ==============================================
# SERVER CONFIGURATION
# ==============================================
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ==============================================
# TRADING CONFIGURATION
# ==============================================
ENABLE_REAL_TRADING=false
POSITION_SAFETY_ENABLED=true
MANDATORY_STOP_LOSS=true
MANDATORY_TAKE_PROFIT=true
MAX_LEVERAGE=10

# ==============================================
# ENTERPRISE CONFIGURATION
# ==============================================
ENTERPRISE_MODE=true
ENTERPRISE_VERSION=6.0.0

# ==============================================
# EXCHANGE RATE API (Opcional)
# ==============================================
# EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# ==============================================
# IMPORTANTE: SEGURANÇA
# ==============================================
# NUNCA FAÇA COMMIT DO ARQUIVO .env NO GIT
# SEMPRE USE VARIÁVEIS DE AMBIENTE EM PRODUÇÃO
# ESTE É APENAS UM EXEMPLO - CONFIGURE COM SUAS CREDENCIAIS REAIS

# Porta padrão do servidor Express
PORT=8080

# URL do banco de dados PostgreSQL (exemplo Railway)
DATABASE_URL=postgres://usuario:senha@host:porta/banco

# Chave da API OpenAI para integração IA de relatórios
OPENAI_API_KEY=

# Chaves Bybit (produção e testnet)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_BASE_URL_TEST=https://api-testnet.bybit.com

# Chaves Binance (produção e testnet)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE=https://api.binance.com
BINANCE_API_BASE_TEST=https://testnet.binance.vision

# Chave CoinStats para coleta de dados de sentimento/mercado
COINSTATS_API_KEY=

# Variáveis do dashboard restrito
DASHBOARD_USER=admin
DASHBOARD_PASS=senha_forte

# WhatsApp - Integração ZAPI
ZAPI_INSTANCE=
ZAPI_TOKEN=

# Número do admin para alertas
ADMIN_PHONE=

# Configuração de logging
LOG_LEVEL=info

# Outras variáveis específicas do projeto (ex: fila de jobs, chave Gemini, integração Make/Zapier, etc)
# MAKE_API_KEY=
# GEMINI_API_KEY=
# NOTIFICA_EMAIL=

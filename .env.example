# PORTA DO SERVIDOR
PORT=8080

# COINSTATS API KEY (dados de mercado)
COINSTATS_API_KEY=

# TOKEN DE SEGURANÇA PARA WEBHOOKS
WEBHOOK_TOKEN=

# Ambiente do Node
NODE_ENV=production

# CONEXÃO COM BANCO DE DADOS POSTGRES
DATABASE_URL=
DATABASE_SSL=true

# BYBIT E BINANCE — URLs BASE (produção e testnet)
BYBIT_BASE_URL_REAL=https://api.bybit.com
BYBIT_BASE_URL_TEST=https://api-testnet.bybit.com
BINANCE_API_BASE=https://api.binance.com
BINANCE_API_BASE_TEST=https://testnet.binance.vision

# CREDENCIAIS DO DASHBOARD DE ADMINISTRAÇÃO (WordPress)
DASHBOARD_USER=
DASHBOARD_PASS=

# SECRET DE JWT PARA AUTENTICAÇÃO
JWT_SECRET=

# CHAVE OPENAI PARA IA
OPENAI_API_KEY=

# CREDENCIAIS ZAPI (WhatsApp)
ZAPI_INSTANCE=
ZAPI_TOKEN=

# TOKEN DE ADMIN (uso interno, ex: integração)
ADMIN_TOKEN=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=


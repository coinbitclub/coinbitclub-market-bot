    "nodemailer": "^7.0.5",
    "openai": "^5.10.2",
    "pg": "^8.16.3",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "socket.io-client": "^4.8.1",
    "stripe": "^18.3.0",
    "styled-components": "^6.1.19",
    "uuid": "^11.1.0",
    "zustand": "^5.0.6"

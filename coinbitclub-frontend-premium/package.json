    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.0.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "^15.4.4",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  }

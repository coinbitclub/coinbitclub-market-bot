{
  "name": "coinbitclub-marketbot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:tailwind": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix-all": "npm run lint:fix && npm run format",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "preview": "next start",
    "setup": "yarn install && yarn build",

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_app_password

# ===== INTEGRATIONS =====
# OpenAI
OPENAI_API_KEY=sua_openai_api_key

# CoinStats
COINSTATS_API_KEY=sua_coinstats_api_key

# Stripe

# Railway Environment Variables Template
# Copy these to your Railway project environment variables

# Database
DATABASE_URL=your_postgresql_database_url_here
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=coinbitclub_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_32_chars

# API Keys (Add your real keys in Railway dashboard)
OPENAI_API_KEY=your_openai_api_key_here
COINSTATS_API_KEY=your_coinstats_api_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Exchange APIs
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# App Settings
NODE_ENV=production
PORT=3000
API_PORT=8081
ADMIN_PORT=8082

# CORS
CORS_ORIGIN=https://your-railway-domain.railway.app

# Email (if using)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASS=your_email_password

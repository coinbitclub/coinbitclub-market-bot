# Dockerfile para Railway - Com Common
FROM node:18-alpine

WORKDIR /app

# Copiar package.json do api-gateway
COPY backend/api-gateway/package*.json ./

# Instalar dependências
RUN npm ci --omit=dev

# Copiar arquivos common necessários
COPY backend/common ./common/

# Copiar código do api-gateway
COPY backend/api-gateway ./

# Expor porta
EXPOSE 8081

# Iniciar aplicação
CMD ["npm", "start"]

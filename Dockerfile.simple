# Dockerfile para Railway - Versão Simplificada
FROM node:18-alpine

WORKDIR /app

# Copiar arquivos common necessários primeiro
COPY backend/common ./common/

# Copiar package.json do api-gateway
COPY backend/api-gateway/package*.json ./

# Instalar dependências
RUN npm ci --omit=dev

# Copiar todo código do api-gateway (incluindo src/)
COPY backend/api-gateway/ ./

# Expor porta
EXPOSE $PORT

# Verificar estrutura (debug)
RUN ls -la && ls -la src/

# Iniciar aplicação
CMD ["npm", "start"]

# Configurações do Sistema Financeiro - CoinBitClub
# Renomeie este arquivo para .env e preencha com suas credenciais reais

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET_HERE

# 🗄️ Database Configuration (PostgreSQL Railway)
DATABASE_URL=postgresql://username:password@host:port/database

# 🤖 OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# 🪙 CoinStats API
COINSTATS_API_KEY=your_coinstats_api_key_here

# IP Fixo - Ngrok Configuration
NGROK_AUTH_TOKEN=314SgsgTA9RpH3gJJenmvEEOnu3_3uXNyK3QBwE4u8vZa7tFZ
NGROK_REGION=us
NGROK_SUBDOMAIN=coinbitclub-bot

# ⚙️ Sistema de Leitura do Mercado
AUTO_START=true
CYCLE_INTERVAL=900000
CLEANUP_HOURS=24
API_TIMEOUT=10000

# 🌐 Server Configuration
PORT=3000
NODE_ENV=production

# API Keys
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_secret
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_here

# Sistema de Comissões
COMMISSION_RATE=0.20
MINIMUM_WITHDRAWAL=50.00
AFFILIATE_COMMISSION_RATE=0.10

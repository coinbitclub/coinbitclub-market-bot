# ===========================================
# CoinBitClub Market Bot - Environment Variables
# ===========================================

# Environment
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/coinbitclub
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coinbitclub
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Message Queue (RabbitMQ)
AMQP_URL=amqp://guest:guest@localhost:5672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
AMQP_HOST=localhost
AMQP_PORT=5672
AMQP_USER=guest
AMQP_PASSWORD=guest

# API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# CoinStats API
COINSTATS_API_KEY=your-coinstats-api-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=1h

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@coinbitclub.com

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# API Gateway
API_GATEWAY_PORT=3000

# Service Ports
SIGNAL_INGESTOR_PORT=9001
SIGNAL_PROCESSOR_PORT=9012
DECISION_ENGINE_PORT=9011
ORDER_EXECUTOR_PORT=9013
ACCOUNTING_PORT=9010
NOTIFICATIONS_PORT=9014
ADMIN_PANEL_PORT=9015

# Risk Management
MAX_CONCURRENT_OPERATIONS=2
MAX_CAPITAL_USAGE_PCT=60
MIN_BALANCE_USD=15
MIN_BALANCE_BRL=60

# Trading Configuration
DEFAULT_LEVERAGE=10
TAKE_PROFIT_MULTIPLIER=1
STOP_LOSS_MULTIPLIER=3

# Time Windows (minutes)
SIGNAL_TIME_WINDOW=30
CLEANUP_INTERVAL_HOURS=72

# Fear & Greed Thresholds
FG_MIN_THRESHOLD=0
FG_MAX_THRESHOLD=100
BTC_DOMINANCE_THRESHOLD=0.3

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Redis (for caching if needed)
REDIS_URL=redis://localhost:6379

# Webhook URLs for external services
TRADINGVIEW_WEBHOOK_SECRET=your-tradingview-webhook-secret

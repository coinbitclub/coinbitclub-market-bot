{
  "name": "api-gateway",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node server.cjs",
    "dev": "nodemon src/index.js",
    "migrate": "knex migrate:latest",
    "db:migrate": "knex migrate:latest",
    "db:seed": "knex seed:run", 
    "db:setup": "npm run db:migrate && npm run db:seed",
    "test": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "async-retry": "^1.3.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^2.0.6",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "opossum": "^8.0.0",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "prom-client": "^15.1.0",
    "stripe": "^14.12.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}

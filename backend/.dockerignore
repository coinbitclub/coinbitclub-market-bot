# 🚀 COINBITCLUB DOCKERIGNORE
# Ignorar arquivos desnecessários no build Docker

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs
logs/
*.log
*.log.*

# Environment files (serão passados via variáveis)
.env*
!.env.production

# Development files
.git/
.gitignore
README.md
*.md

# Testing
coverage/
.nyc_output/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/

# Analytics
analytics-out/

# ML Dashboard (não necessário em produção)
ml-dashboard/

# Documentation
docs/

# Scripts de desenvolvimento
*.test.js
test-*.js
verify-*.js
check-*.js

# Arquivos temporários
*.tmp
*.temp

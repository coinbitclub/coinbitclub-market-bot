{
  "name": "coinbitclub-market-bot-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx kill-port 3000 3001 8080 8090 && nodemon --exec \"node -r dotenv/config\" src/index.js",
    "start:prod": "cross-env NODE_ENV=production node -r dotenv/config src/index.js",
    "start:test": "cross-env NODE_ENV=test node -r dotenv/config src/index.js",
    "test": "jest --runInBand",
    "bot": "node -r dotenv/config src/tradingBot.js",
    "train": "node -r dotenv/config src/trainModel.js",
    "worker": "node -r dotenv/config src/worker.js",
    "migrate": "node-pg-migrate up --pattern \"^202[0-9]+.*\\.js$\""
  },
  "dependencies": {
    "@sentry/node": "^7.48.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.8.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.10.0",
    "prom-client": "^14.1.0",
    "swagger-ui-express": "^4.6.3",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.6.1",
    "nodemon": "^3.0.1",
    "node-pg-migrate": "^7.7.0"
  }
}

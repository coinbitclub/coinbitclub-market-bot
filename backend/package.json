{
  "type": "module",
  "name": "coinbitclub-market-bot-backend",
  "version": "1.0.0",
  "description": "Backend do CoinbitClub Market Bot — API Express, PostgreSQL, Stripe, scheduler e Webhooks",
  "main": "src/index.js",
  "scripts": {
    "dev": "npx kill-port 3000 3001 8080 8090 && nodemon --exec \"node -r dotenv/config\" src/index.js",
    "start": "npm run start:prod",
    "start:prod": "cross-env NODE_ENV=production node -r dotenv/config src/index.js",
    "start:test": "cross-env NODE_ENV=test node -r dotenv/config src/index.js",
    "start:dev": "npm run dev",
    "bot": "node -r dotenv/config src/tradingBot.js",
    "train": "node -r dotenv/config src/trainModel.js",
    "worker": "node -r dotenv/config src/worker.js",
    "migrate": "node-pg-migrate up --pattern \"^202[0-9]+.*\\.js$\"",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@sentry/node": "^7.53.0",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-basic-auth": "^1.2.1",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^6.7.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "openai": "^5.8.2",
    "pg": "^8.16.2",
    "pino": "^8.21.0",
    "pino-pretty": "^8.1.0",
    "prom-client": "^15.1.3",
    "stripe": "^14.21.0",
    "swagger-ui-express": "^4.6.3",
    "technicalindicators": "^3.1.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "babel-jest": "^30.0.4",
    "dotenv-cli": "^7.0.0",
    "jest": "^30.0.4",
    "kill-port": "^2.0.1",
    "nock": "^14.0.5",
    "node-pg-migrate": "^6.2.1",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  },
  "engines": {
    "node": ">=16"
  }
}

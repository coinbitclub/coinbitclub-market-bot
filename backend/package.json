{
  "type": "module",
  "name": "coinbitclub-market-bot-backend",
  "version": "1.0.0",
  "description": "Backend do CoinbitClub Market Bot — API Express, PostgreSQL, Stripe, scheduler e Webhooks",
  "main": "src/index.js",
  "scripts": {
    "prestart": "npx kill-port 3000 3001 8080 8090",
    "start": "node -r dotenv/config src/index.js",
    "dev": "npx kill-port 3000 3001 8080 8090 && nodemon --exec \"node -r dotenv/config\" src/index.js",
    "start:test": "npx kill-port 3000 3001 && node -r dotenv/config src/index.js --env=test",
    "start:prod": "npx kill-port 3000 3001 && node -r dotenv/config src/index.js --env=production",
    "bot": "node -r dotenv/config src/tradingBot.js",
    "train": "node -r dotenv/config src/trainModel.js",
    "worker": "node -r dotenv/config src/worker.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-basic-auth": "^1.2.1",
    "express-jwt": "^8.5.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "openai": "^5.8.2",
    "pg": "^8.16.2",
    "pino": "^8.21.0",
    "pino-pretty": "^8.1.0",
    "prom-client": "^15.1.3",
    "stripe": "^14.21.0",
    "technicalindicators": "^3.1.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.0.0",
    "jest": "^30.0.4",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  },

  "engines": {
    "node": ">=16"
  }
}

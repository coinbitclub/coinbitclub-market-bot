# 🔑 CONFIGURAÇÃO DE CHAVES PARA TESTE DE PRODUÇÃO
# Configure suas chaves API reais aqui para teste

# ==========================================
# INSTRUÇÕES IMPORTANTES
# ==========================================
# 1. Este arquivo contém chaves sensíveis - NÃO COMMITAR
# 2. Use apenas chaves de TESTNET para primeiros testes
# 3. Configure permissões mínimas necessárias
# 4. Use IP whitelist nas exchanges

# ==========================================
# BYBIT - CONFIGURAÇÃO PARA USUÁRIO MAURO
# ==========================================
# Para criar chaves:
# 1. Acesse: https://www.bybit.com/app/user/api-management
# 2. Clique em "Create New Key"
# 3. Selecione permissões:
#    - Read: ✅ Enabled
#    - Spot Trading: ✅ Enabled
#    - Derivatives Trading: ✅ Enabled (se necessário)
# 4. Configure IP whitelist (recomendado)
# 5. Copie as chaves abaixo:

BYBIT_API_KEY=sua_api_key_bybit_aqui
BYBIT_API_SECRET=sua_api_secret_bybit_aqui
BYBIT_TESTNET=true

# ==========================================
# BINANCE - TESTE SECUNDÁRIO
# ==========================================
# Para criar chaves:
# 1. Acesse: https://www.binance.com/en/my/settings/api-management
# 2. Crie nova API Key
# 3. Permissões: Spot Trading
# 4. Configure IP whitelist

BINANCE_API_KEY=sua_api_key_binance_aqui
BINANCE_API_SECRET=sua_api_secret_binance_aqui
BINANCE_TESTNET=true

# ==========================================
# OKX - TESTE TERCIÁRIO
# ==========================================
# Para criar chaves:
# 1. Acesse: https://www.okx.com/account/my-api
# 2. Crie nova API Key
# 3. Configure passphrase forte
# 4. Permissões: Spot Trading, Read

OKX_API_KEY=sua_api_key_okx_aqui
OKX_API_SECRET=sua_api_secret_okx_aqui
OKX_PASSPHRASE=sua_passphrase_okx_aqui
OKX_TESTNET=true

# ==========================================
# COINATS (JÁ CONFIGURADA)

{
  "name": "coinbitclub-marketbot-backend",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "npx kill-port 3000 3001 8080 8090 && nodemon --exec \"node -r dotenv/config\" src/index.js",
    "build": "echo \"No build step needed for pure Node.js; migrate only\"",
    "lint": "eslint \"src/**/*.js\" \"src/**/*.mjs\"",
    "start": "cross-env NODE_ENV=production USE_REAL_AI=true dotenv -e .env.production node src/index.js",
    "start:real": "cross-env NODE_ENV=production USE_REAL_AI=true PORT=8080 dotenv -e .env.production node src/index.js",
    "start:testnet": "cross-env NODE_ENV=testnet USE_REAL_AI=false PORT=8090 dotenv -e .env.testnet node src/index.js",
    "test": "cross-env NODE_ENV=test dotenv -e .env.test -- jest --runInBand --detectOpenHandles --forceExit",
    "test:profile": "node tests/profile.test.js",
    "bot": "node -r dotenv/config src/tradingBot.js",
    "train": "node -r dotenv/config src/trainModel.js",
    "worker": "node -r dotenv/config src/worker.js",
    "migrate": "node-pg-migrate up --pattern \"^202[0-9]+.*\\\\.js$\""
  },
  "dependencies": {
    "axios": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.11.2",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.6.3",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.4",
    "openai": "^5.8.3",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "prom-client": "^15.1.3",
    "stripe": "^18.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "babel-jest": "^30.0.4",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "nock": "^14.0.5",
    "node-pg-migrate": "^7.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^6.3.4"
  }
}

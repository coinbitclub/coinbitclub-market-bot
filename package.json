{
  "name": "coinbitclub-market-bot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prestart": "npx kill-port 3000 3001",
    "start": "node src/index.js",
    "dev": "npx kill-port 3000 3001 && nodemon --exec \"node -r dotenv/config\" src/index.js",
    "token": "node -r dotenv/config -e \"console.log(require('jsonwebtoken').sign({}, process.env.WEBHOOK_JWT_SECRET))\""
  },
  "dependencies": {
    "axios": "^1.x",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.x",
    "express": "^4.x",
    "express-jwt": "^8.5.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.x",
    "morgan": "^1.10.0",
    "pg": "^8.x",
    "prom-client": "^15.x"
  },
  "devDependencies": {
    "kill-port": "^2.x",
    "nodemon": "^3.x"
  }
}

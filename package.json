{
  "type": "module",
  "name": "coinbitclub-market-bot",
  "version": "1.0.0",
  "description": "Market data collector and webhook receiver",
  "main": "src/index.js",
  "scripts": {
    "prestart": "npx kill-port 3000 3001",
    "start": "node src/index.js",
    "dev": "npx kill-port 3000 3001 && nodemon --exec \"node -r dotenv/config\" src/index.js",
    "start:test": "npx kill-port 3000 3001 && node -r dotenv/config src/index.js --env=test",
    "start:prod": "npx kill-port 3000 3001 && node -r dotenv/config src/index.js --env=production"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-basic-auth": "^1.2.1",
    "express-jwt": "^8.5.1",
    "express-prom-bundle": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.16.2",
    "pino": "^8.21.0",
    "pino-pretty": "^8.1.0",
    "prom-client": "^15.1.3",
    "technicalindicators": "^3.1.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.0.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.10"
  }
}
